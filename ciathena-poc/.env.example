# ─────────────────────────────────────────────────────────────────────────────
# ciATHENA Domain Intelligence Agent — environment configuration
#
# Copy this file to `.env` and fill in your real values:
#     cp .env.example .env
#
# With NO values set, the pipeline still runs end-to-end offline using a
# deterministic fake embedder + stubbed LLM (useful for wiring/smoke tests).
# Set the Azure values below for real retrieval quality and real answers.
# ─────────────────────────────────────────────────────────────────────────────

# --- Azure OpenAI: embeddings (ingest + query) --------------------------------
# Embeddings may live on a DIFFERENT Azure resource than the chat model.
# If they share one resource, set the same endpoint/key for both sections.
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://ciatciaiopenai01.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=ciathena-text-embedding-3-large
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

# --- Azure OpenAI: chat (router + answer generation) --------------------------
# The chat model deployment (gpt-4o / gpt-4.1 / etc.) for query routing and
# grounded answer generation.
AZURE_OPENAI_CHAT_ENDPOINT=
AZURE_OPENAI_CHAT_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_CHAT_API_VERSION=2024-02-01

# --- Azure Blob Storage: artifact storage (optional) -------------------------
# When set, artifacts are stored in / loaded from Azure Blob Storage.
# When absent, the pipeline uses the local artifacts/ directory (existing behavior).
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=ciathena-artifacts

# --- Retrieval / agent tunables (optional; sensible defaults in code) ---------
# Where the local Chroma DB is persisted
CHROMA_PERSIST_DIR=./.chroma
# Candidate pool pulled before rerank, and final count kept after rerank
RETRIEVAL_CANDIDATE_POOL=12
RETRIEVAL_TOP_K=4
